<Window x:Class="MyPanelCarWashing.ScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="График работы"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="1000" MinHeight="600"
        Width="1200" Height="700"
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        WindowStyle="None"
        WindowState="Maximized"
        Foreground="Black">

    <Window.Resources>
        <Style x:Key="HeaderCellStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DayHeaderCellStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderCellStyle}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ГРАФИК РАБОТЫ СОТРУДНИКОВ" FontSize="20" FontWeight="Black" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,15" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="◀" Click="PrevMonth_Click" Width="35" Height="35" FontSize="16" FontWeight="Bold" Background="#3498DB" Foreground="White" BorderThickness="0"/>
                <Border Background="White" BorderBrush="#BDC3C7" BorderThickness="1,1,1,1" Padding="15,0" Margin="5,0" Width="200" Height="40">
                    <TextBlock x:Name="MonthYearText" TextAlignment="Center" Text="Апрель 2026" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <Button Content="▶" Click="NextMonth_Click" Width="35" Height="35" FontSize="16" FontWeight="Bold" Background="#3498DB" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="🔧 Создать по шаблону" Click="TemplateButton_Click" Height="35" Padding="15,0" Margin="0,0,10,0" Background="#F39C12" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Легенда (Левый клик - переключить, Правый клик - очистить):" FontWeight="Medium" Margin="0,0,15,0" VerticalAlignment="Center"/>
            <Border Width="15" Height="15" Background="#A9DFBF" BorderBrush="Gray" BorderThickness="1"/>
            <TextBlock Text=" Р - Рабочий" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <Border Width="15" Height="15" Background="#FAD7A1" BorderBrush="Gray" BorderThickness="1"/>
            <TextBlock Text=" В - Выходной" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <Border Width="15" Height="15" Background="#ed7669" BorderBrush="Gray" BorderThickness="1"/>
            <TextBlock Text=" П - Пропуск" VerticalAlignment="Center" Margin="0,0,10,0"/>
        </StackPanel>

        <Border Grid.Row="3" Background="#2C3E50" Height="45" CornerRadius="4,4,0,0">
            <Grid x:Name="HeaderGrid" Background="#2C3E50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" MinWidth="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Сотрудник / День" Style="{StaticResource HeaderCellStyle}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,8"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="4" 
              VerticalScrollBarVisibility="Auto" 
              HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="ScheduleGrid" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" MinWidth="120"/>
                </Grid.ColumnDefinitions>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button x:Name="SaveButton" 
                    Content="💾 Сохранить" 
                    Click="SaveButton_Click" 
                    MinWidth="100" Height="35" 
                    Margin="20,5,5,5" 
                    Background="#27AE60" 
                    Foreground="White"
                    IsEnabled="False"/>
            <Button Content="✖ Закрыть" Click="CloseButton_Click" 
                    MinWidth="100" Height="35"
                    Margin="5"
                    Background="#E74C3C"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
