<Application x:Class="MyPanelCarWashing.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MyPanelCarWashing">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/AppStyles.xaml"/>
                <ResourceDictionary Source="Styles/OrderCardTemplate.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            

            <!-- Конвертеры -->
            <local:BoolToRoleConverter x:Key="BoolToRoleConverter"/>
            <local:IntToBoolConverter x:Key="IntToBoolConverter"/>
            <local:PercentageConverter x:Key="PercentageConverter"/>
            <local:ActiveToStatusConverter x:Key="ActiveToStatusConverter"/>
            <local:ActiveToColorConverter x:Key="ActiveToColorConverter"/>
            <local:ActiveToBackgroundConverter x:Key="ActiveToBackgroundConverter"/>
            <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <local:CompletedToStatusConverter x:Key="CompletedToStatusConverter"/>
            <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <local:StatusToBackgroundConverter x:Key="StatusToBackgroundConverter"/>
            <local:AppointmentToStyleConverter x:Key="AppointmentToStyleConverter"/>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <local:AppointmentToBackgroundConverter x:Key="AppointmentToBackgroundConverter"/>
            <local:ItemStyleConverter x:Key="ItemStyleConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
