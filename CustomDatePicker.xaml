<UserControl x:Class="MyPanelCarWashing.CustomDatePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="400">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="DateTextBox" Grid.Column="0" Height="50" Width="300" Padding="0" 
                 IsReadOnly="True" Background="White" Cursor="Hand"
                 MouseDown="DateTextBox_MouseDown"
                 BorderBrush="#BDC3C7" BorderThickness="1"
                 HorizontalContentAlignment="Center"/>
        
        <Button Grid.Column="1" Width="30" Height="35" Content="📅" 
                Background="#3498DB" Foreground="White" BorderThickness="0"
                Cursor="Hand" Click="CalendarButton_Click"/>

        <Popup x:Name="CalendarPopup" PlacementTarget="{Binding ElementName=DateTextBox}" 
               Placement="Bottom" StaysOpen="False" PopupAnimation="Slide">
            <Border Background="White" BorderBrush="#BDC3C7" BorderThickness="1" 
                    CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="◀" Width="30" Height="35" 
                                Background="#ECF0F1" BorderThickness="0" Cursor="Hand"
                                Click="PrevMonth_Click"/>

                        <TextBlock x:Name="MonthYearText" Grid.Column="1" 
                                   FontSize="14" FontWeight="Bold" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Button Grid.Column="2" Content="▶" Width="30" Height="35" 
                                Background="#ECF0F1" BorderThickness="0" Cursor="Hand"
                                Click="NextMonth_Click"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Пн" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="Вт" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="2" Text="Ср" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="3" Text="Чт" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="4" Text="Пт" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="5" Text="Сб" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="6" Text="Вс" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                    </Grid>

                    <UniformGrid x:Name="CalendarGrid" Grid.Row="2" Columns="7" Rows="6"/>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
