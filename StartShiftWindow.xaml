<Window x:Class="MyPanelCarWashing.StartShiftWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="Начать смену"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="600" Height="950"
        Background="White">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новая смена" FontSize="24" FontWeight="Bold" 
                   Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,20" Grid.Row="0"/>

        <Label Content="Дата смены:" FontSize="15" Grid.Row="1" Margin="0,5" FontWeight="SemiBold"/>
        <DatePicker x:Name="ShiftDatePicker" Grid.Row="2" Margin="0,5" Height="30" 
                    SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                    DisplayDateStart="{Binding MinDate, Mode=OneWay}"
                    Background="White"/>

        <Label Content="Выберите сотрудников:" FontSize="15" Grid.Row="3" Margin="0,10,0,5" FontWeight="SemiBold"/>
        
        <!-- Используем ItemsControl вместо ListBox для полного контроля -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Foreground="Black">
            <ItemsControl ItemsSource="{Binding Employees}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#BDC3C7" BorderThickness="0,0,0,1" Padding="10,5">
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                      Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FullName}" FontSize="15" Margin="5,0" Foreground="Black"/>
                                    <TextBlock Text="{Binding IsAdmin, Converter={StaticResource BoolToRoleConverter}}" 
                                               FontSize="9" Foreground="Gray" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="5" Margin="0,15">
            <Button Content="✅ Начать смену" Click="StartShiftButton_Click" Width="120" Height="35" 
                    Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
            <Button Content="✖ Отмена" Click="CloseButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#95A5A6" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>