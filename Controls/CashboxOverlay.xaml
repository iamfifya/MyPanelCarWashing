<UserControl x:Class="MyPanelCarWashing.Controls.CashboxOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MyPanelCarWashing.Controls"
             Background="Transparent">

    <UserControl.Resources>
        <Storyboard x:Key="ShowAnimation">
            <DoubleAnimation Storyboard.TargetName="OverlayBackground" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="PopupPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="OverlayBackground" Background="#90000000" Opacity="0" Visibility="Collapsed">
            <Button Background="Transparent" BorderThickness="0" Click="Close_Click"/>
        </Border>

        <Border x:Name="PopupPanel" Background="#F5F6FA" CornerRadius="15" Width="950" Height="650" 
                VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#DCDDE1" BorderThickness="1"
                Opacity="0" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
            </Border.RenderTransform>

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,20" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="💰 Касса смены" FontSize="26" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>
                    <Button  Click="Close_Click" DockPanel.Dock="Right" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="✕" VerticalAlignment="Center" FontSize="20" Foreground="Black"/>
                    </Button>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="💵 Наличных в ящике" FontSize="12" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding CashInHand, StringFormat={}{0:N0} ₽}" FontSize="24" FontWeight="Bold" Foreground="#27AE60"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15" Margin="5,0,5,0">
                        <StackPanel>
                            <TextBlock Text="📉 Расходы / Авансы" FontSize="12" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding TotalExpenses, StringFormat={}{0:N0} ₽}" FontSize="24" FontWeight="Bold" Foreground="#E74C3C"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#34495E" CornerRadius="10" Padding="15" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="🏢 Чистая прибыль (наличная)" FontSize="12" Foreground="#BDC3C7"/>
                            <TextBlock Text="{Binding NetCashProfit, StringFormat={}{0:N0} ₽}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,15,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="📜 Лента операций" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ListBox ItemsSource="{Binding Transactions}" BorderThickness="1" Background="Transparent" HorizontalContentAlignment="Stretch" Foreground="Black">

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="10"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F1F2F6" BorderThickness="0" Padding="5,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Icon}" FontSize="18" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                    <TextBlock Text="{Binding Type}" FontWeight="Bold" FontSize="11"/>
                                                    <TextBlock Text="{Binding Comment}" FontSize="11" Foreground="#7F8C8D"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding FormattedAmount}" FontWeight="Bold" 
                                                           Foreground="{Binding ColorHex}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="➕ Новая операция" FontWeight="Bold" Margin="0,0,0,15"/>

                            <controls:CustomComboBox x:Name="TypeCashTransactionCombo" 
                                                     Margin="0,5,0,10" 
                                                     Height="50"
                                                     ItemsSource="{Binding OperationTypes}"
                                                     SelectedValue="{Binding SelectedOperationType, Mode=TwoWay}"
                                                     SelectedValuePath="Value"
                                                     DisplayMemberPath="Key"
                                                     Placeholder="Выберите тип операции"/>

                            <controls:CustomComboBox x:Name="EmployeeCombo" 
                                                     Margin="0,0,0,10" 
                                                     Height="50"
                                                     Visibility="{Binding EmployeeComboVisibility}"
                                                     ItemsSource="{Binding ActiveEmployees}"
                                                     SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                                                     DisplayMemberPath="FullName"
                                                     Placeholder="Кому выдаем аванс?"/>

                            <TextBlock Text="Сумма (₽)" FontSize="11" Margin="0,0,0,5"/>
                            <TextBox x:Name="AmountText" Height="40" FontSize="11" FontWeight="Bold" Padding="5" Margin="0,0,0,15"/>

                            <TextBlock Text="Комментарий" FontSize="11" Margin="0,0,0,5"/>
                            <TextBox x:Name="CommentText" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Padding="5" Margin="0,0,0,20"/>

                            <Button Content="Провести операцию" Click="AddTransaction_Click" 
                                    Height="45" Background="#3498DB" Foreground="White" FontWeight="Bold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
