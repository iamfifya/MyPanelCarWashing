<Window x:Class="MyPanelCarWashing.CustomReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="Выборочный отчет"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="800" MinHeight="600"
        Width="900" Height="700"
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        WindowStyle="None"
        WindowState="Maximized"
        Foreground="Black">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📊 Выборочный отчет" FontSize="24" FontWeight="Bold" 
                   Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15" Grid.Row="0"/>

        <!-- Выбор периода -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="С:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <local:CustomDatePicker x:Name="StartDatePicker" Grid.Column="1" Height="50" Width="400"/>

            <Label Grid.Column="2" Content="По:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <local:CustomDatePicker x:Name="EndDatePicker" Grid.Column="3" Height="50" Width="400"/>

            <Button Grid.Column="4" Content="📊 Сформировать отчет" Click="GenerateReportButton_Click" 
                    Width="180" Height="35" Margin="10,0,0,0"/>
        </Grid>

        <!-- Контент отчета -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="White">
            <StackPanel>
                <StackPanel x:Name="ReportContent" Visibility="Collapsed">
                    <!-- Информация о периоде -->
                    <Border Background="#E8F0FE" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock x:Name="PeriodText" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock x:Name="DaysCountText" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Итоговая статистика -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="🚗 Всего машин" FontSize="12" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="TotalCarsText" FontSize="24" FontWeight="Bold" 
                                           Foreground="#2C3E50" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="💰 Общая выручка" FontSize="12" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="TotalRevenueText" FontSize="24" FontWeight="Bold" 
                                           Foreground="#27AE60" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="👤 Мойщикам (35%)" FontSize="12" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="TotalWasherText" FontSize="24" FontWeight="Bold" 
                                           Foreground="#8E44AD" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="🏢 Компании (65%)" FontSize="12" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="TotalCompanyText" FontSize="24" FontWeight="Bold" 
                                           Foreground="#E67E22" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Таблица по дням -->
                    <TextBlock Text="📅 Отчет по дням" FontSize="16" FontWeight="Bold" 
                               Foreground="#2C3E50" Margin="0,0,0,10" Background="White"/>

                    <ListView x:Name="DailyReportsList" Height="250" Background="White">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Дата" Width="100" DisplayMemberBinding="{Binding Date, StringFormat=dd.MM.yyyy}"/>
                                <GridViewColumn Header="Машин" Width="80" DisplayMemberBinding="{Binding Cars}"/>
                                <GridViewColumn Header="Выручка" Width="120" DisplayMemberBinding="{Binding Revenue, StringFormat={}{0:N0} ₽}"/>
                                <GridViewColumn Header="Мойщикам" Width="120" DisplayMemberBinding="{Binding WasherEarnings, StringFormat={}{0:N0} ₽}"/>
                                <GridViewColumn Header="Компании" Width="120" DisplayMemberBinding="{Binding CompanyEarnings, StringFormat={}{0:N0} ₽}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Заработная плата сотрудников -->
                    <TextBlock Text="💰 Заработная плата сотрудников" FontSize="16" FontWeight="Bold" 
                               Foreground="#2C3E50" Margin="0,15,0,5"/>
                    <TextBlock Text="(35% от выручки по заказам, которые выполнил сотрудник)" 
                               FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,10"/>

                    <ListView x:Name="EmployeesSalaryList" Height="200" Background="White">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Сотрудник" Width="180" DisplayMemberBinding="{Binding EmployeeName}"/>
                                <GridViewColumn Header="Кол-во машин" Width="100" DisplayMemberBinding="{Binding CarsWashed}"/>
                                <GridViewColumn Header="Выручка сотрудника" Width="140" DisplayMemberBinding="{Binding TotalAmount, StringFormat={}{0:N0} ₽}"/>
                                <GridViewColumn Header="Заработная плата (35%)" Width="150" DisplayMemberBinding="{Binding Earnings, StringFormat={}{0:N0} ₽}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Детальная статистика по сотрудникам -->
                    <TextBlock Text="👥 Детальная статистика сотрудников" FontSize="16" FontWeight="Bold" 
                               Foreground="#2C3E50" Margin="0,15,0,10"/>

                    <Expander Header="Развернуть детальную статистику по дням" Margin="0,0,0,10">
                        <ItemsControl x:Name="EmployeesDetailControl" Margin="0,5" Foreground="Black">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" CornerRadius="8" Padding="10" Margin="0,5">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="Bold" Foreground="#2C3E50">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} - {1:N0} ₽ (всего {2} машин)">
                                                        <Binding Path="EmployeeName"/>
                                                        <Binding Path="Earnings"/>
                                                        <Binding Path="CarsWashed"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>

                                            <ItemsControl ItemsSource="{Binding DailyWork}" Margin="0,10,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="White" CornerRadius="5" Padding="8" Margin="0,2" >
                                                            <Grid >
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="100"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Date, StringFormat=dd.MM.yyyy}" 
                                                                           FontWeight="SemiBold" Foreground="Black"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding CarsWashed, StringFormat=🚗 {0} машин}" 
                                                                           Margin="10,0"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Earnings, StringFormat=💰 {0:N0} ₽}" 
                                                                           Foreground="#27AE60" FontWeight="Bold"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </StackPanel>

                <TextBlock x:Name="NoDataText" Text="Выберите период и нажмите 'Сформировать отчет'" 
                           FontSize="14" Foreground="#7F8C8D" HorizontalAlignment="Center" 
                           Margin="0,50,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="📄 Экспорт" Click="ExportButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#27AE60" Foreground="White"/>
            <Button Content="✖ Закрыть" Click="CloseButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
