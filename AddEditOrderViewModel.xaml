<!-- AddEditOrderWindow.xaml -->
<Window x:Class="MyPanelCarWashing.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        xmlns:controls="clr-namespace:MyPanelCarWashing.Controls"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="550" Height="850"
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        WindowStyle="SingleBorderWindow"
        Foreground="Black">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:DecimalToEmptyZeroConverter x:Key="DecimalToEmptyZeroConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="True"
                  Margin="0">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0: Заголовок -->
                <RowDefinition Height="Auto"/>
                <!-- 1: Марка и модель -->
                <RowDefinition Height="Auto"/>
                <!-- 2: Марка и модель textbox -->
                <RowDefinition Height="Auto"/>
                <!-- 3: Госномер -->
                <RowDefinition Height="Auto"/>
                <!-- 4: Госномер textbox -->
                <RowDefinition Height="Auto"/>
                <!-- 5: Категория кузова -->
                <RowDefinition Height="Auto"/>
                <!-- 6: Категория кузова combobox -->
                <RowDefinition Height="Auto"/>
                <!-- 7: Время заезда -->
                <RowDefinition Height="Auto"/>
                <!-- 8: Время заезда grid -->
                <RowDefinition Height="Auto"/>
                <!-- 9: Длительность (только запись) -->
                <RowDefinition Height="Auto"/>
                <!-- 10: Длительность textbox -->
                <RowDefinition Height="Auto"/>
                <!-- 11: Выбор бокса -->
                <RowDefinition Height="Auto"/>
                <!-- 12: Radio buttons -->
                <RowDefinition Height="Auto"/>
                <!-- 13: Выбор мойщика -->
                <RowDefinition Height="Auto"/>
                <!-- 14: Мойщик combobox -->
                <RowDefinition Height="Auto"/>
                <!-- 15: Выбор услуг -->
                <RowDefinition Height="Auto"/>
                <!-- 16: Services listbox -->
                <RowDefinition Height="Auto"/>
                <!-- 17: Доп. стоимость -->
                <RowDefinition Height="Auto"/>
                <!-- 18: Доп. стоимость textbox -->
                <RowDefinition Height="Auto"/>
                <!-- 19: Причина -->
                <RowDefinition Height="Auto"/>
                <!-- 20: Причина textbox -->
                <RowDefinition Height="Auto"/>
                <!-- 21: Статус (только заказ) -->
                <RowDefinition Height="Auto"/>
                <!-- 22: Статус combobox -->
                <RowDefinition Height="Auto"/>
                <!-- 23: Клиент -->
                <RowDefinition Height="Auto"/>
                <!-- 24: Клиент grid -->
                <RowDefinition Height="Auto"/>
                <!-- 25: Способ оплаты -->
                <RowDefinition Height="Auto"/>
                <!-- 26: Оплата combobox -->
                <RowDefinition Height="Auto"/>
                <!-- 27: Итоговая сумма -->
                <RowDefinition Height="Auto"/>
                <!-- 27: Итоговая сумма -->
                <RowDefinition Height="Auto"/>
                <!-- 27: Итоговая сумма -->
                <RowDefinition Height="Auto"/>
                <!-- 28: Кнопки -->
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding WindowTitle}" FontSize="24" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15" Grid.Row="0"/>
            
            <!-- Выбор клиента (только для заказов) -->
            <Label Content="👤 Клиент:" Grid.Row="1" Margin="0,5,0,0" FontWeight="SemiBold"
       Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            <Grid Grid.Row="2" Margin="0,5,0,10"
      Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <controls:CustomComboBox x:Name="ClientComboBox" Grid.Column="0" Height="50"
             DisplayMemberPath="DisplayInfo"
             SelectedValuePath="Id"
             IsEditable="True"
             Placeholder="Начните вводить имя или телефон"
             SelectionChanged="ClientComboBox_SelectionChanged"/>
                <Button Grid.Column="1" Content="➕" Click="AddNewClient_Click" 
            Width="35" Height="50" Margin="5,0,0,0"
            Background="#27AE60" Foreground="White" FontSize="16"/>
            </Grid>

            <!-- Марка и модель -->
            <Label Content="Марка и модель авто:" Grid.Row="3" Margin="0,5,0,0" FontWeight="SemiBold"/>
            <TextBox Text="{Binding CurrentOrder.CarModel, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="4" Margin="0,5,0,10" Height="50" Padding="5" Foreground="Black"/>

            <!-- Госномер -->
            <Label Content="Государственный номер:" Grid.Row="5" Margin="0,5,0,0" FontWeight="SemiBold"/>
            <TextBox Text="{Binding CurrentOrder.CarNumber, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="6" Margin="0,5,0,10" Height="50" Padding="5" Foreground="Black"/>

            <!-- Категория кузова -->
            <Label Content="Категория кузова:" Grid.Row="7" Margin="0,5,0,0" FontWeight="SemiBold"/>
            <controls:CustomComboBox x:Name="BodyTypeComboBox" Grid.Row="8" Margin="0,5,0,10" Height="50"
                         SelectedValue="{Binding SelectedBodyTypeCategory}"
                         SelectedValuePath="Tag"
                         Placeholder="Выберите категорию"/>

            <!-- Время заезда -->
            <Label Content="⏰ Время заезда:" Grid.Row="9" Margin="0,5,0,0" FontWeight="SemiBold"/>
            <Grid Grid.Row="10" Margin="0,5,0,10" Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <local:CustomDatePicker x:Name="OrderDatePicker" Grid.Column="0" Height="50"/>
                <TextBlock Grid.Column="1" Text=" " VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="OrderTimeTextBox" Grid.Column="2" TextAlignment="Center" Height="50" Width="80" Text="12:00"/>
            </Grid>

            <!-- Длительность (только для записей) -->
            <Label Content="⏱️ Длительность (минуты):" Grid.Row="11" Margin="0,5,0,0" FontWeight="SemiBold"
                   Visibility="{Binding IsAppointment, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBox x:Name="DurationTextBox" Grid.Row="12" Margin="0,5,0,10" Height="50" Padding="5" Text="60"
                     Visibility="{Binding IsAppointment, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Выбор бокса -->
            <Label Content="🚘 Выберите бокс:" Grid.Row="13" Margin="0,5,0,0" FontWeight="SemiBold"/>
            <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                <RadioButton Content="Бокс 1" GroupName="BoxNumber" Foreground="Black"
                             IsChecked="{Binding CurrentOrder.BoxNumber, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}" 
                             Margin="10,5" Height="30" VerticalAlignment="Center"/>
                <RadioButton Content="Бокс 2" GroupName="BoxNumber" Foreground="Black"
                             IsChecked="{Binding CurrentOrder.BoxNumber, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}" 
                             Margin="10,5" Height="30" VerticalAlignment="Center"/>
                <RadioButton Content="Бокс 3" GroupName="BoxNumber" Foreground="Black"
                             IsChecked="{Binding CurrentOrder.BoxNumber, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3}" 
                             Margin="10,5" Height="30" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Выбор мойщика (только для заказов) -->
            <Label Content="👤 Выберите мойщика:" Grid.Row="15" Margin="0,5,0,0" FontWeight="SemiBold"
                   Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            <controls:CustomComboBox x:Name="WasherComboBox" Grid.Row="15" Margin="0,5,0,10" Height="50"
                                     ItemsSource="{Binding Washers}"
                                     SelectedValue="{Binding CurrentOrder.WasherId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     DisplayMemberPath="FullName"
                                     SelectedValuePath="Id"
                                     Placeholder="Выберите из списка"
                                     IsEditable="True"
                                     Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

            <!-- Выбор услуг -->
            <Label Content="🛠️ Выберите услуги:" Grid.Row="17" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <ListBox x:Name="ServicesListBox" Grid.Row="18" MinHeight="120" MaxHeight="180" Margin="0,5,0,10"
                     ItemsSource="{Binding Services}" SelectionMode="Multiple">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,8"/>
                        <Setter Property="MinHeight" Value="40"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" Grid.Column="0" 
                                       VerticalAlignment="Center" TextWrapping="Wrap" Foreground="Black"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" Grid.Column="1" 
                                       Foreground="#27AE60" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Дополнительная стоимость -->
            <Label Content="💰 Дополнительная стоимость:" Grid.Row="19" Margin="0,10,0,0" FontWeight="SemiBold"/>
            <TextBox Text="{Binding ExtraCost, 
           UpdateSourceTrigger=PropertyChanged, 
           TargetNullValue=0, 
           FallbackValue=0,
           ValidatesOnExceptions=False,
           Converter={StaticResource DecimalToEmptyZeroConverter}}"
           Grid.Row="20" Margin="0,5,0,10" Height="50" Padding="5"/>

            <!-- Причина доп. стоимости -->
            <Label Content="📝 Причина дополнительной стоимости:" Grid.Row="21" Margin="0,5,0,0" FontWeight="SemiBold"/>
            <TextBox Text="{Binding CurrentOrder.ExtraCostReason, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="22" Margin="0,5,0,10" Height="50" Padding="5" 
                     TextWrapping="Wrap" AcceptsReturn="True"/>

            <!-- Статус заказа -->
            <Label Content="📋 Статус заказа:" Grid.Row="23" Margin="0,5,0,0" FontWeight="SemiBold"
                   Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            <controls:CustomComboBox x:Name="StatusComboBox" Grid.Row="24" Margin="0,5,0,10" Height="50"
                         SelectedValue="{Binding CurrentOrder.Status}"
                         SelectedValuePath="Tag"
                         Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

            <!-- Скидка -->
            <Label Content="🎁 Скидка:" Grid.Row="25" Margin="0,10,0,0" FontWeight="SemiBold"/>
            <Grid Grid.Row="26" Margin="0,5,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="DiscountPercentTextBox" 
                        Text="{Binding DiscountPercent, 
                        UpdateSourceTrigger=PropertyChanged, 
                        TargetNullValue=0, 
                        FallbackValue=0,
                        ValidatesOnExceptions=False,
                        Converter={StaticResource DecimalToEmptyZeroConverter}}"
                        Grid.Column="0" 
                        Height="50" 
                        Padding="5" />

                <TextBlock Grid.Column="1" Text=" % " VerticalAlignment="Center" Margin="5,0" FontSize="14"/>

                <TextBox x:Name="DiscountAmountTextBox" 
             Grid.Column="2" 
             Height="50" 
             Padding="5" 
             Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToEmptyZeroConverter}}"/>
            </Grid>

            <!-- Способ оплаты (только для заказов) -->
            <Label Content="💳 Способ оплаты:" Grid.Row="27" Margin="0,10,0,0" FontWeight="SemiBold"
                   Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            <controls:CustomComboBox x:Name="PaymentMethodComboBox" Grid.Row="28" Margin="0,5,0,10" Height="50"
                         SelectedValuePath="Tag"
                         Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

            <!-- Итоговая сумма -->
            <Border Grid.Row="29" Background="#F0F8FF" CornerRadius="5" Padding="10" Margin="0,10">
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="#7F8C8D" 
                   HorizontalAlignment="Center" Text="{Binding ServicesTotal, StringFormat=💰 Услуги: {0:N0} ₽}"/>
                    <TextBlock FontSize="12" Foreground="#E67E22" 
                   HorizontalAlignment="Center" Text="{Binding ExtraCost, StringFormat=➕ Дополнительно: {0:N0} ₽}"/>
                    <TextBlock FontSize="12" Foreground="#E74C3C" 
                   HorizontalAlignment="Center" Text="{Binding DiscountAmount, StringFormat=🎁 Скидка: {0:N0} ₽}"
                   Visibility="{Binding DiscountAmount, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#27AE60"
                   HorizontalAlignment="Center" Text="{Binding FinalTotal, StringFormat=💰 Итого: {0:N0} ₽}"/>
                    <TextBlock FontSize="10" Foreground="#7F8C8D" 
                   HorizontalAlignment="Center" Text="{Binding WasherEarningsDisplay, StringFormat='👤 Мойщику: {0:N0} ₽'}"/>
                    <TextBlock FontSize="10" Foreground="#7F8C8D" 
                   HorizontalAlignment="Center" Text="{Binding CompanyEarningsDisplay, StringFormat='🏢 Компании: {0:N0} ₽'}"/>
                </StackPanel>
            </Border>

            <!-- Кнопки -->
            <StackPanel Grid.Row="30" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,20">
                <Button x:Name="ConvertToOrderButton" Content="📅 Преобразовать в заказ" Click="ConvertToOrderButton_Click" 
                        Width="185" Height="35" Margin="0,5" Background="#9B59B6" Foreground="White"
                        Visibility="{Binding IsAppointment, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="✅ Сохранить" Click="SaveButton_Click" Width="120" Height="35" 
                        Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
                <Button Content="✖ Отмена" Click="CloseButton_Click" Width="100" Height="35" 
                        Margin="5" Background="#E74C3C" Foreground="White" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
