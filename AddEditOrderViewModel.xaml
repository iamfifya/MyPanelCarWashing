<!-- AddEditOrderWindow.xaml -->
<Window x:Class="MyPanelCarWashing.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="550" Height="850"
        Background="#F5F6FA">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:IntToBoolConverter x:Key="IntToBoolConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding WindowTitle}" FontSize="24" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15" Grid.Row="0"/>

            <!-- Марка и модель -->
            <Label Content="Марка и модель авто:" Grid.Row="1" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox Text="{Binding CurrentOrder.CarModel, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="2" Margin="0,5" Height="50" Padding="5" Foreground="Black"/>

            <!-- Госномер -->
            <Label Content="Государственный номер:" Grid.Row="3" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox Text="{Binding CurrentOrder.CarNumber, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="4" Margin="0,5" Height="50" Padding="5" Foreground="Black"/>

            <!-- Тип кузова (категория) -->
            <Label Content="Категория кузова:" Grid.Row="5" Margin="0,5" FontWeight="SemiBold"/>
            <ComboBox x:Name="BodyTypeComboBox" Grid.Row="6" Margin="0,5" Height="50"
          SelectedValue="{Binding SelectedBodyTypeCategory}"
          SelectedValuePath="Tag">
                <ComboBoxItem Content="Категория 1 (Седан/Купе)" Tag="1"/>
                <ComboBoxItem Content="Категория 2 (Хэтчбек)" Tag="2"/>
                <ComboBoxItem Content="Категория 3 (Универсал)" Tag="3"/>
                <ComboBoxItem Content="Категория 4 (Внедорожник/Минивэн)" Tag="4"/>
            </ComboBox>

            <!-- Время заезда -->
            <Label Content="⏰ Время заезда:" Grid.Row="7" Margin="0,5" FontWeight="SemiBold"/>
            <Grid Grid.Row="8" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <local:CustomDatePicker x:Name="OrderDatePicker" Grid.Column="0" Height="50"/>
                <TextBlock Grid.Column="1" Text=" " VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="OrderTimeTextBox" Grid.Column="2" Height="50" Width="80" Text="12:00"/>
            </Grid>

            <!-- Выбор бокса -->
            <Label Content="🚘 Выберите бокс:" Grid.Row="9" Margin="0,5" FontWeight="SemiBold"/>
            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                <RadioButton Content="Бокс 1" GroupName="BoxNumber" 
                             IsChecked="{Binding CurrentOrder.BoxNumber, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}" 
                             Margin="10,5"/>
                <RadioButton Content="Бокс 2" GroupName="BoxNumber" 
                             IsChecked="{Binding CurrentOrder.BoxNumber, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}" 
                             Margin="10,5"/>
                <RadioButton Content="Бокс 3" GroupName="BoxNumber" 
                             IsChecked="{Binding CurrentOrder.BoxNumber, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3}" 
                             Margin="10,5"/>
            </StackPanel>

            <!-- Выбор мойщика - видим для заказов, скрыт для записей -->
            <Label Content="👤 Выберите мойщика:" Grid.Row="11" Margin="0,5" FontWeight="SemiBold"
                   Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            <ComboBox x:Name="WasherComboBox" Grid.Row="12" Margin="0,5" Height="30" 
                      ItemsSource="{Binding Washers}" SelectedValue="{Binding CurrentOrder.WasherId}"
                      DisplayMemberPath="FullName" SelectedValuePath="Id"
                      Visibility="{Binding IsAppointment, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

            <!-- Выбор услуг -->
            <Label Content="🛠️ Выберите услуги:" Grid.Row="13" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <ListBox x:Name="ServicesListBox" Grid.Row="14" MinHeight="150" MaxHeight="250" Margin="0,5"
                     ItemsSource="{Binding Services}" SelectionMode="Multiple">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,8"/>
                        <Setter Property="MinHeight" Value="45"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" Grid.Column="0" 
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" Grid.Column="1" 
                                       Foreground="#27AE60" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Дополнительная стоимость -->
            <Label Content="💰 Дополнительная стоимость:" Grid.Row="15" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox Text="{Binding ExtraCost, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="16" Margin="0,5" Height="50" Padding="5"/>

            <!-- Причина доп. стоимости -->
            <Label Content="📝 Причина дополнительной стоимости:" Grid.Row="17" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox Text="{Binding CurrentOrder.ExtraCostReason, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Row="18" Margin="0,5" Height="60" Padding="5" 
                     TextWrapping="Wrap" AcceptsReturn="True"/>

            <!-- Статус заказа (только для редактирования) -->
            <Label Content="📋 Статус заказа:" Grid.Row="19" Margin="0,5" FontWeight="SemiBold"
                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <ComboBox x:Name="StatusComboBox" Grid.Row="20" Margin="0,5" Height="40"
                      Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <ComboBoxItem Content="🟡 В ожидании"/>
                <ComboBoxItem Content="🟢 Выполняется"/>
                <ComboBoxItem Content="✅ Выполнен"/>
                <ComboBoxItem Content="❌ Отменен"/>
            </ComboBox>

            <!-- Способ оплаты -->
            <Label Content="💳 Способ оплаты:" Grid.Row="21" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <ComboBox x:Name="PaymentMethodComboBox" Grid.Row="22" Margin="0,5" Height="40" 
                      SelectedValue="{Binding CurrentOrder.PaymentMethod}" SelectedIndex="0">
                <ComboBoxItem Content="💵 Наличные"/>
                <ComboBoxItem Content="💳 Карта"/>
                <ComboBoxItem Content="📱 Перевод"/>
            </ComboBox>

            <!-- Итоговая сумма -->
            <Border Grid.Row="23" Background="#F0F8FF" CornerRadius="5" Padding="10" Margin="0,10">
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="#7F8C8D" 
                               HorizontalAlignment="Center" Text="{Binding ServicesTotal, StringFormat=💰 Услуги: {0:N0} ₽}"/>
                    <TextBlock FontSize="12" Foreground="#E67E22" 
                               HorizontalAlignment="Center" Text="{Binding ExtraCost, StringFormat=➕ Дополнительно: {0:N0} ₽}"/>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="#27AE60"
                               HorizontalAlignment="Center" Text="{Binding FinalTotal, StringFormat=💰 Итого: {0:N0} ₽}"/>
                </StackPanel>
            </Border>

            <!-- Кнопка конвертации записи -->
            <Button x:Name="ConvertToOrderButton" Content="📅 Преобразовать в заказ" Click="ConvertToOrderButton_Click" 
                    Grid.Row="24" Width="200" Height="35" Margin="0,10" Background="#9B59B6" Foreground="White"
                    Visibility="{Binding IsAppointment, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="25" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <Button Content="✅ Сохранить" Click="SaveButton_Click" Width="120" Height="35" 
                        Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
                <Button Content="✖ Отмена" Click="CloseButton_Click" Width="100" Height="35" 
                        Margin="5" Background="#95A5A6" Foreground="White" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
