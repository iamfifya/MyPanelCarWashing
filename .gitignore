```gitignore
# Build artifacts
bin/
obj/
*.exe
*.dll
*.pdb
*.userprefs
*.cache
*.log

# Dependencies
packages/
node_modules/
.nuget/

# IDE files
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.temp
*.bak
*.cache
*.log
```