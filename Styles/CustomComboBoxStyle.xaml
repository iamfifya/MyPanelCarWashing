<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MyPanelCarWashing.Controls">

    <Style TargetType="{x:Type controls:CustomComboBox}">
        <Setter Property="Height" Value="35"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#BDC3C7"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CustomComboBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock x:Name="HeaderText"
                                   Grid.Row="0"
                                   Text="{TemplateBinding Header}"
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="10,5,10,0"/>

                        <!-- Основное поле (кликабельное) -->
                        <Border x:Name="PART_MainBorder"
                                Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Height="{TemplateBinding Height}"
                                Cursor="Hand">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- TextBox -->
                                <TextBox x:Name="PART_TextBox"
                                         Grid.Column="0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="10,0,0,0"
                                         VerticalAlignment="Center"
                                         IsReadOnly="{TemplateBinding IsEditable}"
                                         Foreground="Black"
                                         FontSize="13"
                                         IsHitTestVisible="False"/>

                                <!-- Кнопка-стрелка -->
                                <ToggleButton x:Name="PART_ToggleButton"
                                              Grid.Column="1"
                                              Width="30"
                                              Height="30"
                                              Margin="0,0,5,0"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="True">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <Path x:Name="Arrow"
                                                      Fill="#7F8C8D"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 5 5 L 10 0 Z"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="Data" Value="M 0 5 L 5 0 L 10 5 Z"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>
                        </Border>

                        <!-- Выпадающий список -->
                        <Popup x:Name="PART_Popup"
                               PlacementTarget="{Binding ElementName=PART_MainBorder}"
                               Placement="Bottom"
                               StaysOpen="False"
                               Width="{Binding ActualWidth, ElementName=PART_MainBorder}">

                            <Border Background="White"
                                    BorderBrush="#BDC3C7"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Margin="0,2,0,0">
                                <ScrollViewer x:Name="PART_ScrollViewer"
                                              MaxHeight="250"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PART_ItemsPanel" 
                                                Orientation="Vertical"
                                                Background="White"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="#3498DB"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="Header" Value="{x:Null}">
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Header" Value="">
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
