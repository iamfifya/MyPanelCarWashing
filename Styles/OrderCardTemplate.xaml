<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MyPanelCarWashing">

    <!-- Стили карточек -->
    <Style x:Key="OrderCardStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="BorderBrush" Value="#BDC3C7"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="AppointmentCardStyle" TargetType="Border" BasedOn="{StaticResource OrderCardStyle}">
        <Setter Property="Background" Value="#FFF8E1"/>
        <Setter Property="BorderBrush" Value="#FFD54F"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="SelectedOrderCardStyle" TargetType="Border" BasedOn="{StaticResource OrderCardStyle}">
        <Setter Property="Background" Value="#E3F2FD"/>
        <Setter Property="BorderBrush" Value="#2196F3"/>
        <Setter Property="BorderThickness" Value="3"/>
    </Style>

    <Style x:Key="SelectedAppointmentCardStyle" TargetType="Border" BasedOn="{StaticResource AppointmentCardStyle}">
        <Setter Property="Background" Value="#FFF3E0"/>
        <Setter Property="BorderBrush" Value="#FF9800"/>
        <Setter Property="BorderThickness" Value="3"/>
    </Style>

    <!-- DataTemplate для OrderDisplayItem -->
    <DataTemplate DataType="{x:Type local:OrderDisplayItem}">
        <Border>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="BorderBrush" Value="#BDC3C7"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="MaxWidth" Value="300"/>
                    <!-- Добавляем ограничение ширины -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="#E3F2FD"/>
                            <Setter Property="BorderBrush" Value="#2196F3"/>
                            <Setter Property="BorderThickness" Value="3"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsAppointment}" Value="True">
                            <Setter Property="Background" Value="#FFF8E1"/>
                            <Setter Property="BorderBrush" Value="#FFD54F"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSelected}" Value="True"/>
                                <Condition Binding="{Binding IsAppointment}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#FFF3E0"/>
                            <Setter Property="BorderBrush" Value="#FF9800"/>
                            <Setter Property="BorderThickness" Value="3"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="{Binding CarNumber}" FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>
                    <TextBlock Text=" 📅" FontSize="12" Foreground="#FF9800" 
                           Visibility="{Binding IsAppointment, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <TextBlock Text="{Binding CarModel}" FontSize="12" Foreground="#7F8C8D"/>
                <TextBlock Text="{Binding Time, StringFormat={}{0:HH:mm}}" FontSize="11" Foreground="#95A5A6"/>
                <TextBlock Text="{Binding WasherName}" FontSize="11" Foreground="#3498DB"/>

                <!-- ИСПРАВЛЕННЫЙ TextBlock для услуг -->
                <TextBlock Text="{Binding ServicesList}" 
                       FontSize="10" 
                       Foreground="#95A5A6" 
                       TextWrapping="Wrap"
                       Margin="0,2,0,2"/>

                <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:N0} ₽}" FontWeight="Bold" Foreground="#27AE60"/>
                <TextBlock Text="{Binding ExtraCost, StringFormat=➕ {0:N0} ₽}" 
                       FontSize="10" Foreground="#E67E22" Margin="0,2,0,0"
                       Visibility="{Binding ExtraCost, Converter={StaticResource ZeroToVisibilityConverter}}"/>

                <TextBlock Text="{Binding ExtraCostReason}" FontSize="9" Foreground="#E67E22" 
                       TextWrapping="Wrap" Visibility="{Binding ExtraCost, Converter={StaticResource ZeroToVisibilityConverter}}"/>

                <Border CornerRadius="10" Padding="5,2" Margin="0,5,0,0" 
                    Background="{Binding Status, Converter={StaticResource StatusToBackgroundConverter}}"
                    HorizontalAlignment="Center">
                    <TextBlock FontSize="9" Foreground="White" Text="{Binding Status}"/>
                </Border>
            </StackPanel>
        </Border>
    </DataTemplate>
</ResourceDictionary>
