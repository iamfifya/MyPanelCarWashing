<Window x:Class="MyPanelCarWashing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="Панель управления автомойкой"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="1200" MinHeight="700"
        Width="1400" Height="800"
        FontFamily="Segoe UI"
        WindowState="Maximized">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопками -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <WrapPanel>
                <Button Content="🚗 Добавить заказ" x:Name="AddButton" Click="AddButton_Click" 
                        Width="140" Margin="5" Background="#3498DB" Foreground="White"/>
                <Button Content="👥 Сотрудники" x:Name="EmployeesButton" Click="EmployeesButton_Click" 
                        Width="120" Margin="5" Background="#2C3E50" Foreground="White"/>
                <Button Content="⏰ Начать смену" x:Name="StartShiftButton" Click="StartShiftButton_Click" 
                        Width="120" Margin="5" Background="#27AE60" Foreground="White"/>
                <Button Content="🔒 Закрыть смену" x:Name="CloseShiftButton" Click="CloseShiftButton_Click" 
                        Width="120" Margin="5" Background="#E74C3C" Foreground="White"/>
                <Button Content="📊 Отчеты" x:Name="ReportsButton" Click="ReportsButton_Click" 
                        Width="100" Margin="5" Background="#F39C12" Foreground="White"/>
                <Button Content="🚪 Выход" x:Name="ExitButton" Click="ExitButton_Click" 
                        Width="100" Margin="5" Background="#95A5A6" Foreground="White"/>
                <Label Content="🔍 Поиск:" VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                <TextBox Width="200" x:Name="SearchFilterTextBox" KeyUp="SearchFilterTextBox_KeyUp" 
                         VerticalContentAlignment="Center" Margin="5" Padding="5"/>
            </WrapPanel>
        </Border>

        <!-- Три колонки для боксов -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Бокс 1 -->
            <Border Grid.Column="0" Background="#F8F9FA" CornerRadius="10" Margin="5">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#3498DB" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                        <TextBlock Text="🚘 БОКС 1" FontSize="18" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="Box1ItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="5" Margin="0,5" Padding="10" 
                                            BorderBrush="#BDC3C7" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <TextBlock Grid.Row="0" FontSize="14" FontWeight="Bold" 
                                                       Text="{Binding CarModel}" Foreground="#2C3E50"/>
                                            <TextBlock Grid.Row="1" FontSize="11" 
                                                       Text="{Binding CarNumber}" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="2" FontSize="11" 
                                                       Text="{Binding Time, StringFormat=⏰ {0:HH:mm}}" 
                                                       Foreground="#27AE60" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="3" FontSize="11" 
                                                       Text="{Binding WasherName, StringFormat=👤 Мойщик: {0}}" 
                                                       Foreground="#8E44AD" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="4" FontSize="11" 
                                                       Text="{Binding ServicesList, StringFormat=🛠️ Услуги: {0}}" 
                                                       Foreground="#E67E22" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Row="5" FontSize="12" FontWeight="Bold"
                                                       Text="{Binding TotalPrice, StringFormat=💰 {0:C}}" 
                                                       Foreground="#27AE60" Margin="0,5,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Бокс 2 -->
            <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="10" Margin="5">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#27AE60" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                        <TextBlock Text="🚘 БОКС 2" FontSize="18" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="Box2ItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="5" Margin="0,5" Padding="10" 
                                            BorderBrush="#BDC3C7" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <TextBlock Grid.Row="0" FontSize="14" FontWeight="Bold" 
                                                       Text="{Binding CarModel}" Foreground="#2C3E50"/>
                                            <TextBlock Grid.Row="1" FontSize="11" 
                                                       Text="{Binding CarNumber}" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="2" FontSize="11" 
                                                       Text="{Binding Time, StringFormat=⏰ {0:HH:mm}}" 
                                                       Foreground="#27AE60" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="3" FontSize="11" 
                                                       Text="{Binding WasherName, StringFormat=👤 Мойщик: {0}}" 
                                                       Foreground="#8E44AD" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="4" FontSize="11" 
                                                       Text="{Binding ServicesList, StringFormat=🛠️ Услуги: {0}}" 
                                                       Foreground="#E67E22" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Row="5" FontSize="12" FontWeight="Bold"
                                                       Text="{Binding TotalPrice, StringFormat=💰 {0:C}}" 
                                                       Foreground="#27AE60" Margin="0,5,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Бокс 3 -->
            <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="10" Margin="5">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#E74C3C" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                        <TextBlock Text="🚘 БОКС 3" FontSize="18" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="Box3ItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="5" Margin="0,5" Padding="10" 
                                            BorderBrush="#BDC3C7" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <TextBlock Grid.Row="0" FontSize="14" FontWeight="Bold" 
                                                       Text="{Binding CarModel}" Foreground="#2C3E50"/>
                                            <TextBlock Grid.Row="1" FontSize="11" 
                                                       Text="{Binding CarNumber}" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="2" FontSize="11" 
                                                       Text="{Binding Time, StringFormat=⏰ {0:HH:mm}}" 
                                                       Foreground="#27AE60" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="3" FontSize="11" 
                                                       Text="{Binding WasherName, StringFormat=👤 Мойщик: {0}}" 
                                                       Foreground="#8E44AD" Margin="0,2,0,0"/>
                                            <TextBlock Grid.Row="4" FontSize="11" 
                                                       Text="{Binding ServicesList, StringFormat=🛠️ Услуги: {0}}" 
                                                       Foreground="#E67E22" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Row="5" FontSize="12" FontWeight="Bold"
                                                       Text="{Binding TotalPrice, StringFormat=💰 {0:C}}" 
                                                       Foreground="#27AE60" Margin="0,5,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя панель с информацией и статистикой -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Информация о смене -->
                <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding CurrentShiftInfo}" FontSize="12" Foreground="#2C3E50"/>
                    <TextBlock Text="{Binding TotalOrdersInfo}" FontSize="12" FontWeight="Bold" 
                               Foreground="#27AE60" Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- Разделитель -->
                <Border Grid.Column="1" Width="1" Background="#BDC3C7" Margin="20,0"/>
                
                <!-- Статистика по мойщикам -->
                <!-- Нижняя панель с информацией и статистикой -->
<!-- Нижняя панель с информацией и статистикой -->
<Border Grid.Row="2" Background="#F0F0F0" Padding="10" CornerRadius="5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Информация о смене -->
        <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left">
            <TextBlock Text="{Binding CurrentShiftInfo}" FontSize="12" Foreground="#2C3E50"/>
            <TextBlock Text="{Binding TotalOrdersInfo}" FontSize="12" FontWeight="Bold" 
                       Foreground="#27AE60" Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Разделитель -->
        <Border Grid.Column="1" Width="1" Background="#BDC3C7" Margin="20,0"/>
        
        <!-- Статистика по мойщикам -->
        <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right">
            <TextBlock Text="👥 Заработок мойщиков:" FontSize="12" FontWeight="Bold" 
                       Foreground="#2C3E50" Margin="0,0,0,5"/>
            <ItemsControl ItemsSource="{Binding WashersStats}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="11">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}: {1} машин | {2:C} (35%)">
                                    <Binding Path="WasherName"/>
                                    <Binding Path="CarsCount"/>
                                    <Binding Path="Earnings"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Separator Margin="0,5,0,5" Height="1" Background="#BDC3C7"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="💰 Компания: " FontSize="12" FontWeight="Bold" Foreground="#27AE60"/>
                <TextBlock Text="{Binding CompanyEarnings, StringFormat={}{0:C}}" FontSize="12" 
                           FontWeight="Bold" Foreground="#27AE60"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Border>
    </Grid>
</Border>
    </Grid>
</Window>