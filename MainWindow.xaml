<Window x:Class="MyPanelCarWashing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель управления автомойкой" Height="650" Width="1000"
        Background="#F5F5F5">

    <Grid>
        <TabControl>
            <TabItem Header="📋 Смена">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель даты -->
                    <Border Grid.Row="0" Style="{StaticResource StatCard}" Margin="5">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="Дата смены:" VerticalAlignment="Center" Margin="5" FontWeight="SemiBold"/>
                            <DatePicker x:Name="DatePicker" SelectedDateChanged="DatePicker_SelectedDateChanged" Width="150" Margin="5"/>
                        </StackPanel>
                    </Border>

                    <!-- Сотрудники смены -->
                    <GroupBox Header="👥 Сотрудники смены" Grid.Row="1" Margin="0,5">
                        <StackPanel>
                            <ListBox x:Name="EmployeesList" Height="100" Margin="5"/>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBox x:Name="NewEmployeeBox" Width="200" Margin="0,0,5,0"/>
                                <Button x:Name="AddEmployeeButton" Content="➕ Добавить сотрудника" Click="AddEmployee_Click" Width="150"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Итоги смены -->
                    <GroupBox Header="📊 Итоги смены" Grid.Row="2" Margin="0,5">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <Border Style="{StaticResource StatCard}" Width="200" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Машин за смену" FontSize="12" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="TotalCarsText" Text="0" FontSize="24" FontWeight="Bold" 
                                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Width="200" Margin="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Выручка" FontSize="12" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="TotalRevenueText" Text="0 ₽" FontSize="24" FontWeight="Bold" 
                                               Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- Заказы -->
                    <GroupBox Header="📝 Заказы" Grid.Row="3" Margin="0,5">
                        <DataGrid x:Name="OrdersGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Номер авто" Binding="{Binding CarNumber}" Width="120"/>
                                <DataGridTextColumn Header="Модель" Binding="{Binding CarModel}" Width="120"/>
                                <DataGridTextColumn Header="Время" Binding="{Binding Time, StringFormat=HH:mm}" Width="80"/>
                                <DataGridTextColumn Header="Услуги" Binding="{Binding ServicesCount}" Width="*"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice, StringFormat={}{0:C}}" Width="100"/>
                                <DataGridTemplateColumn Header="Действия" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✏️ Услуги" Click="SelectServices_Click" Tag="{Binding}" Width="80"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <!-- Кнопки действий -->
                    <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="0,10" HorizontalAlignment="Right">
                        <Button x:Name="AddOrderButton" Content="➕ Добавить заказ" Click="AddOrder_Click" Width="130" Margin="5"/>
                        <Button x:Name="FinishShiftButton" Content="🏁 Завершить смену" Click="FinishShift_Click" 
                                Width="130" Margin="5" Style="{StaticResource WarningButton}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="📅 Все дни">
                <DataGrid x:Name="AllShiftsGrid" AutoGenerateColumns="True" Margin="10"/>
            </TabItem>

            <TabItem Header="📈 Месячный отчет">
                <DataGrid x:Name="MonthlyReportGrid" AutoGenerateColumns="True" Margin="10"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>