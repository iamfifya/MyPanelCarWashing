<Window x:Class="MyPanelCarWashing.WasherSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MyPanelCarWashing.Controls"
        Title="Выбор мойщика"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="500" Height="350"
        Background="#F5F6FA"
        BorderBrush="Black"
        BorderThickness="1"
        WindowStyle="None"
        Foreground="Black">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="👤 Выберите мойщика" FontSize="18" FontWeight="Bold" 
                   Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Label Content="Мойщик:" Grid.Row="1" Margin="0,5" FontWeight="SemiBold"/>

        <controls:CustomComboBox x:Name="WasherComboBox" Grid.Row="2" Margin="0,5,0,15" Height="45"
                                 DisplayMemberPath="FullName"
                                 SelectedValuePath="Id"
                                 Placeholder="Выберите из списка"
                                 IsEditable="True"/>

        <TextBlock Text="⚠️ Если мойщик не в смене, он будет учтён в статистике и добавлен в смену" 
                   Grid.Row="3" FontSize="11" Foreground="#E67E22" 
                   TextWrapping="Wrap" Margin="0,10,0,0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button Content="✅ Выбрать" Click="OkButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
            <Button Content="✖ Отмена" Click="CancelButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#E74C3C" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
