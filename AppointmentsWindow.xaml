<Window x:Class="MyPanelCarWashing.AppointmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="Предварительные записи"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="800" MinHeight="500"
        Width="1000" Height="600"
        Background="#F5F6FA">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📋 Предварительные записи" FontSize="24" FontWeight="Bold" 
                   Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Фильтр по дате -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Показать записи за:" VerticalAlignment="Center"/>
            <local:CustomDatePicker x:Name="FilterDatePicker" Height="30" Width="150" Margin="5"/>
            <Button Content="🔍 Показать" Click="FilterButton_Click" Width="100" Height="30" Margin="5"/>
            <Button Content="➕ Новая запись" Click="NewAppointmentButton_Click" Width="120" Height="30" Margin="5" Background="#27AE60" Foreground="White"/>
            <Button Content="🗑 Удалить" Click="DeleteButton_Click" Width="100" Height="30" Margin="5" Background="#E74C3C" Foreground="White"/>
        </StackPanel>

        <!-- Список записей -->
        <ListView Grid.Row="2" x:Name="AppointmentsListView" SelectionMode="Single" Background="White">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Дата/Время" Width="120" DisplayMemberBinding="{Binding AppointmentDate, StringFormat=dd.MM.yyyy HH:mm}"/>
                    <GridViewColumn Header="Окончание" Width="120" DisplayMemberBinding="{Binding EndTime, StringFormat=HH:mm}"/>
                    <GridViewColumn Header="Марка/Модель" Width="150" DisplayMemberBinding="{Binding CarModel}"/>
                    <GridViewColumn Header="Госномер" Width="100" DisplayMemberBinding="{Binding CarNumber}"/>
                    <GridViewColumn Header="Бокс" Width="50" DisplayMemberBinding="{Binding BoxNumber}"/>
                    <GridViewColumn Header="Услуги" Width="150" DisplayMemberBinding="{Binding ServicesList}"/>
                    <GridViewColumn Header="Сумма" Width="100" DisplayMemberBinding="{Binding TotalPrice, StringFormat={}{0:N0} ₽}"/>
                    <GridViewColumn Header="Статус" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" 
                       Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Content="📋 Показать все записи" Click="ShowAllButton_Click" Width="150" Height="30" Margin="5"/>
            <Button Content="✖ Закрыть" Click="CloseButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
