<Window x:Class="MyPanelCarWashing.EditOrderServicesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="Редактирование услуг"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="450" Height="500"
        Background="White">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Редактирование услуг" FontSize="20" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15" Grid.Row="0"/>

        <Border Grid.Row="1" Background="#F8F9FA" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock FontWeight="Bold" Text="Информация о заказе:"/>
                <TextBlock Text="{Binding CurrentOrder.CarModel}" Margin="0,5,0,0"/>
                <TextBlock Text="{Binding CurrentOrder.CarNumber}"/>
                <TextBlock Text="{Binding CurrentOrder.Time, StringFormat=Время: {0:HH:mm dd.MM.yyyy)}}"/>
                <TextBlock Text="{Binding CurrentOrder.TotalPrice, StringFormat=Текущая сумма: {0:C}}" 
                           Foreground="#27AE60" FontWeight="Bold" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Label Content="Выберите услуги:" Grid.Row="2" Margin="0,5" FontWeight="SemiBold"/>
        
        <ListBox x:Name="ServicesListView" Grid.Row="3" Height="200" Margin="0,5"
                 ItemsSource="{Binding Services}"
                 SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <CheckBox IsChecked="{Binding IsSelected}" Width="20"/>
                        <TextBlock Text="{Binding Name}" Width="180" Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" Foreground="#27AE60"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="4" Margin="0,15">
            <Button Content="✓ Сохранить" Click="SaveButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
            <Button Content="✗ Отмена" Click="CloseButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#95A5A6" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>