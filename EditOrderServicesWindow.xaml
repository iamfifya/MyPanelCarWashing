<Window x:Class="MyPanelCarWashing.EditOrderServicesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование услуг" Height="400" Width="500" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите услуги для заказа:" Margin="5" FontWeight="Bold"/>

        <ListBox x:Name="ServicesListBox" Grid.Row="1" SelectionMode="Multiple" Margin="5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsSelected}" Margin="5"/>
                        <TextBlock Text="{Binding Name}" Width="200" Margin="5"/>
                        <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" Foreground="Green" Margin="5"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="5">
            <Button Content="Сохранить" Click="SaveButton_Click" Width="80" Margin="5" IsDefault="True"/>
            <Button Content="Отмена" Click="CancelButton_Click" Width="80" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>