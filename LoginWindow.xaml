<Window x:Class="MyPanelCarWashing.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Height="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Тут название мойки" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Панель управления" FontSize="14" Foreground="#ECF0F1" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Форма входа -->
        <Border Grid.Row="1" Background="White" Margin="50" CornerRadius="10" 
                BorderBrush="#BDC3C7" BorderThickness="1">
            <StackPanel Margin="30">
                <TextBlock Text="Вход в систему" Style="{StaticResource PageTitle}" FontSize="20" Margin="0,0,0,20"/>

                <TextBlock Text="Логин" Margin="0,10,0,5"/>
                <TextBox x:Name="LoginBox" Height="35" FontSize="14"/>

                <TextBlock Text="Пароль" Margin="0,15,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="35" FontSize="14"/>

                <Button x:Name="LoginButton" Content="Войти" Click="LoginButton_Click" 
                        Height="40" FontSize="14" Margin="0,25,0,0"/>

                <TextBlock Text="Тестовые данные: 1 / 1" 
                           Foreground="#7F8C8D" FontSize="11" 
                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>