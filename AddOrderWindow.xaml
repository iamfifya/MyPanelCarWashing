<Window x:Class="MyPanelCarWashing.AddOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Добавление заказа"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="🚗 Информация об авто" Grid.Row="0" Margin="5">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Номер авто:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="CarNumberBox" Grid.Row="0" Grid.Column="1" Margin="5" Width="200"/>

                <TextBlock Text="Модель:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="CarModelBox" Grid.Row="1" Grid.Column="1" Margin="5" Width="200"/>

                <TextBlock Text="Дата:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <DatePicker x:Name="DatePicker" Grid.Row="2" Grid.Column="1" Margin="5" Width="120"/>

                <TextBlock Text="Время:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="TimeBox" Grid.Row="3" Grid.Column="1" Margin="5" Width="80"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="🛠️ Выберите услуги" Grid.Row="1" Margin="5">
            <ListBox x:Name="ServicesListBox" SelectionMode="Multiple" Height="150" Margin="5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsSelected}" Margin="5" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" Width="180" Margin="5" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" Foreground="{StaticResource SuccessBrush}" 
                                       Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <GroupBox Header="📝 Примечания" Grid.Row="2" Margin="5">
            <TextBox x:Name="NotesBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="5"/>
        </GroupBox>

        <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="5">
            <Button Content="✅ Сохранить" Click="OkButton_Click" Width="100" Margin="5" IsDefault="True"/>
            <Button Content="❌ Отмена" Click="CancelButton_Click" Width="100" Margin="5" IsCancel="True" 
                    Style="{StaticResource DangerButton}"/>
        </StackPanel>
    </Grid>
</Window>