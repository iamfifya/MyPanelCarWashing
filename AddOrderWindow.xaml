<Window x:Class="MyPanelCarWashing.AddOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="Добавление заказа"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="500" Height="550"
        Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новый заказ" FontSize="20" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15" Grid.Row="0"/>

        <Label Content="Марка и модель авто:" Grid.Row="1" Margin="0,5" FontWeight="SemiBold"/>
        <TextBox Text="{Binding NewOrder.CarModel, UpdateSourceTrigger=PropertyChanged}" 
                 Grid.Row="2" Margin="0,5" Height="30" Padding="5"/>

        <Label Content="Государственный номер:" Grid.Row="3" Margin="0,5" FontWeight="SemiBold"/>
        <TextBox Text="{Binding NewOrder.CarNumber, UpdateSourceTrigger=PropertyChanged}" 
                 Grid.Row="4" Margin="0,5" Height="30" Padding="5"/>

        <Label Content="Тип кузова:" Grid.Row="5" Margin="0,5" FontWeight="SemiBold"/>

        <!-- Viewbox для выбора кузова -->
        <Viewbox Grid.Row="6" Height="100" Stretch="Uniform" Margin="0,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#ECF0F1" Margin="5" Padding="10" CornerRadius="5" 
                        Cursor="Hand" MouseLeftButtonUp="BodyType_Click" Tag="Седан">
                    <StackPanel>
                        <TextBlock Text="🚗" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="Седан" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#ECF0F1" Margin="5" Padding="10" CornerRadius="5" 
                        Cursor="Hand" MouseLeftButtonUp="BodyType_Click" Tag="Хэтчбек">
                    <StackPanel>
                        <TextBlock Text="🚙" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="Хэтчбек" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#ECF0F1" Margin="5" Padding="10" CornerRadius="5" 
                        Cursor="Hand" MouseLeftButtonUp="BodyType_Click" Tag="Универсал">
                    <StackPanel>
                        <TextBlock Text="🚐" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="Универсал" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#ECF0F1" Margin="5" Padding="10" CornerRadius="5" 
                        Cursor="Hand" MouseLeftButtonUp="BodyType_Click" Tag="Внедорожник">
                    <StackPanel>
                        <TextBlock Text="🚜" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="Внедорожник" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#ECF0F1" Margin="5" Padding="10" CornerRadius="5" 
                        Cursor="Hand" MouseLeftButtonUp="BodyType_Click" Tag="Купе">
                    <StackPanel>
                        <TextBlock Text="🏎️" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="Купе" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Viewbox>

        <TextBox Text="{Binding SelectedBodyType}" Grid.Row="7" Margin="0,5" Height="30" 
                 IsReadOnly="True" Background="#FFF9E6" Foreground="#E67E22" FontWeight="Bold"
                 VerticalContentAlignment="Center"/>

        <Label Content="Выберите услуги:" Grid.Row="8" Margin="0,10,0,5" FontWeight="SemiBold"/>

        <ListBox Grid.Row="9" ItemsSource="{Binding Services}" Height="150" Margin="0,5"
                 SelectionMode="Multiple" DisplayMemberPath="Name">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="10" Margin="0,15">
            <Button Content="✓ Сохранить" Click="SaveButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
            <Button Content="✗ Отмена" Click="CloseButton_Click" Width="100" Height="35" 
                    Margin="5" Background="#95A5A6" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>