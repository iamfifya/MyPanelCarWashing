<Window x:Class="MyPanelCarWashing.AddOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPanelCarWashing"
        mc:Ignorable="d"
        Title="Добавление заказа"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="550" Height="800"
        Background="#F5F6FA">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Новый заказ" FontSize="24" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15" Grid.Row="0"/>

            <!-- Марка и модель -->
            <Label Content="Марка и модель авто:" Grid.Row="1" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="CarModelTextBox" Grid.Row="2" Margin="0,5" Height="50" Padding="5" Foreground="Black"/>

            <!-- Госномер -->
            <Label Content="Государственный номер:" Grid.Row="3" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="CarNumberTextBox" Grid.Row="4" Margin="0,5" Height="50" Padding="5" Foreground="Black"/>

            <!-- Тип кузова -->
            <Label Content="Тип кузова:" Grid.Row="5" Margin="0,5" FontWeight="SemiBold"/>
            <ComboBox x:Name="BodyTypeComboBox" Grid.Row="6" Margin="0,5" Height="50" Foreground="Black">
                <ComboBoxItem Content="Седан" IsSelected="True"/>
                <ComboBoxItem Content="Хэтчбек"/>
                <ComboBoxItem Content="Универсал"/>
                <ComboBoxItem Content="Внедорожник"/>
                <ComboBoxItem Content="Купе"/>
                <ComboBoxItem Content="Кабриолет"/>
            </ComboBox>

            <!-- Время заезда -->
            <Label Content="⏰ Время заезда:" Grid.Row="7" Margin="0,5" FontWeight="SemiBold"/>
            <Grid Grid.Row="8" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <local:CustomDatePicker x:Name="OrderDatePicker" Grid.Column="0" Height="50"/>
                <TextBlock Grid.Column="1" Text=" " VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="OrderTimeTextBox" Grid.Column="2" Height="50" Width="80" Text="12:00"/>
            </Grid>

            <!-- Выбор бокса -->
            <Label Content="🚘 Выберите бокс:" Grid.Row="9" Margin="0,5" FontWeight="SemiBold"/>
            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                <RadioButton x:Name="Box1Radio" Content="Бокс 1" GroupName="BoxNumber" IsChecked="True" Margin="10,5" FontSize="14" Foreground="Black"/>
                <RadioButton x:Name="Box2Radio" Content="Бокс 2" GroupName="BoxNumber" Margin="10,5" FontSize="14" Foreground="Black"/>
                <RadioButton x:Name="Box3Radio" Content="Бокс 3" GroupName="BoxNumber" Margin="10,5" FontSize="14" Foreground="Black"/>
            </StackPanel>

<!-- Выбор мойщика -->
<Label Content="👤 Выберите мойщика:" Grid.Row="11" Margin="0,5" FontWeight="SemiBold"/>
<ComboBox x:Name="WasherComboBox" Grid.Row="12" Margin="0,5" Height="30" 
          DisplayMemberPath="FullName"/>

            <!-- Выбор услуг -->
            <Label Content="🛠️ Выберите услуги:" Grid.Row="13" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <ListBox x:Name="ServicesListBox" Grid.Row="14" MinHeight="150" MaxHeight="250" Margin="0,5"
         SelectionMode="Multiple"
         SelectionChanged="ServicesListBox_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,8"/>
                        <Setter Property="MinHeight" Value="45"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" Grid.Column="0" 
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" Grid.Column="1" 
                           Foreground="#27AE60" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Дополнительная стоимость -->
            <Label Content="💰 Дополнительная стоимость:" Grid.Row="15" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="ExtraCostTextBox" Grid.Row="16" Margin="0,5" Height="50" Padding="5" 
                     Text="0" TextChanged="ExtraCostTextBox_TextChanged"/>

            <!-- Причина доп. стоимости -->
            <Label Content="📝 Причина дополнительной стоимости:" Grid.Row="17" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="ExtraCostReasonTextBox" Grid.Row="18" Margin="0,5" Height="60" Padding="5" 
                     TextWrapping="Wrap" AcceptsReturn="True"/>

            <!-- Итоговая сумма -->
            <Border Grid.Row="19" Background="#F0F8FF" CornerRadius="5" Padding="10" Margin="0,10">
                <StackPanel>
                    <TextBlock x:Name="ServicesTotalText" FontSize="12" Foreground="#7F8C8D" 
                               HorizontalAlignment="Center" Text="💰 Услуги: 0 ₽"/>
                    <TextBlock x:Name="ExtraCostText" FontSize="12" Foreground="#E67E22" 
                               HorizontalAlignment="Center" Text="➕ Дополнительно: 0 ₽"/>
                    <TextBlock x:Name="TotalPriceTextBlock" FontSize="18" FontWeight="Bold" Foreground="#27AE60"
                               HorizontalAlignment="Center" Text="💰 Итого: 0 ₽"/>
                </StackPanel>
            </Border>


            <!-- Кнопки -->
            <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <Button Content="✅ Сохранить" Click="SaveButton_Click" Width="120" Height="35" 
                        Margin="5" Background="#27AE60" Foreground="White" Cursor="Hand"/>
                <Button Content="✖ Отмена" Click="CloseButton_Click" Width="100" Height="35" 
                        Margin="5" Background="#95A5A6" Foreground="White" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
